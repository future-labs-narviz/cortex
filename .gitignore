# Dependencies
node_modules/
.bun/

# Build output
dist/
src-tauri/target/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Tauri
src-tauri/target/
src-tauri/WixTools/
src-tauri/icons/*.ico
src-tauri/icons/*.icns

# Vault data (user content, not committed)
vault/

# Cortex app data (for any vault, including test-vault by default)
.cortex/

# ...except test-vault IS committed so Cortex works on a fresh clone.
# The negation lifts the .cortex/ exclusion just for this path, then the
# final line re-excludes the regenerated Tantivy binary search index.
!test-vault/.cortex/
test-vault/.cortex/search-index/

# Claude Code project-local settings at the repo root should NOT be
# committed — they're per-user state (accepted permissions, hook config
# that gets written if someone accidentally opens the repo root as a
# Cortex vault). The leading slash scopes this to the repo root so it
# does NOT affect test-vault/.claude/ which IS committed.
/.claude/

# Environment
.env
.env.*
!.env.example

# Logs
*.log

# Lock files are committed
# bun.lock - committed
