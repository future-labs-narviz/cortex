          {
            "type": "http",
            "url": "http://localhost:3847/hooks/session-end"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3847/hooks/prompt"
          }
        ]
      }
